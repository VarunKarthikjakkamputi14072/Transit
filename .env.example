# --- Transit environment configuration ---
# Copy to `.env` and fill in real values.

# Core
APIFORGE_ENV=development
SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Database
DATABASE_URL=postgresql+psycopg2://apiforge:apiforge@localhost:5432/apiforge

# Redis
REDIS_URL=redis://localhost:6379/0

# NVIDIA NIM (build.nvidia.com) — backs POST /api/v1/chat/completions
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.3-70b-instruct

# Rate limit defaults (used to seed rate_limit_config on startup)
FREE_TIER_REQUESTS_PER_HOUR=100
PRO_TIER_REQUESTS_PER_HOUR=5000
