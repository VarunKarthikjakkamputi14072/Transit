# --- Transit environment configuration ---
# Copy to `.env` and fill in real values.

# Core
APIFORGE_ENV=development
SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Database
DATABASE_URL=postgresql+psycopg2://apiforge:apiforge@localhost:5432/apiforge

# Redis
REDIS_URL=redis://localhost:6379/0

# NVIDIA NIM (build.nvidia.com) — primary chat + embeddings backend
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.3-70b-instruct
NVIDIA_EMBEDDING_MODEL=nvidia/nv-embedqa-e5-v5

# Chat waterfall fallbacks (OpenAI-compatible). If NVIDIA is down/rate-limited,
# Transit falls through to these in order. A provider joins the chain only when
# its key is set. Order: NVIDIA → Groq → OpenRouter → Gemini.
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct
# Google Gemma via NVIDIA NIM (separate NIM key → key-level failover)
GOOGLE_API_KEY=
GOOGLE_BASE_URL=https://integrate.api.nvidia.com/v1
GOOGLE_MODEL=google/diffusiongemma-26b-a4b-it
# Google Gemini via its OpenAI-compatible endpoint (optional final fallback)
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
GEMINI_MODEL=gemini-2.0-flash

# Rate limit defaults (used to seed rate_limit_config on startup)
FREE_TIER_REQUESTS_PER_HOUR=100
PRO_TIER_REQUESTS_PER_HOUR=5000

# Response cache TTLs (seconds) — identical requests served from Redis, $0 cost.
# Chat: 24h, Embeddings: 7d (re-embedding identical chunks is pure waste). 0 = off.
CACHE_TTL_CHAT=86400
CACHE_TTL_EMBEDDINGS=604800
