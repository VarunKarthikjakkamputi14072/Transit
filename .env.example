# --- APIForge environment configuration ---
# Copy to `.env` and fill in real values.

# Core
APIFORGE_ENV=development
SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Database
DATABASE_URL=postgresql+psycopg2://apiforge:apiforge@localhost:5432/apiforge

# Redis
REDIS_URL=redis://localhost:6379/0

# Upstream APIs
OPENWEATHER_API_KEY=
NEWSAPI_API_KEY=
ALPHAVANTAGE_API_KEY=

# Rate limit defaults (used to seed rate_limit_config on startup)
FREE_TIER_REQUESTS_PER_HOUR=100
PRO_TIER_REQUESTS_PER_HOUR=5000

# Cache TTLs (seconds)
CACHE_TTL_WEATHER=600
CACHE_TTL_NEWS=300
CACHE_TTL_FINANCE=60
