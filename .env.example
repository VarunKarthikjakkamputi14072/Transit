# --- Transit environment configuration ---
# Copy to `.env` and fill in real values.

# Core
APIFORGE_ENV=development
SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Database
DATABASE_URL=postgresql+psycopg2://apiforge:apiforge@localhost:5432/apiforge

# Redis
REDIS_URL=redis://localhost:6379/0

# NVIDIA NIM (build.nvidia.com) — backs /api/v1/chat/completions + /api/v1/embeddings
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.3-70b-instruct
NVIDIA_EMBEDDING_MODEL=nvidia/nv-embedqa-e5-v5

# Rate limit defaults (used to seed rate_limit_config on startup)
FREE_TIER_REQUESTS_PER_HOUR=100
PRO_TIER_REQUESTS_PER_HOUR=5000

# Response cache TTLs (seconds) — identical requests served from Redis, $0 cost.
# Chat: 24h, Embeddings: 7d (re-embedding identical chunks is pure waste). 0 = off.
CACHE_TTL_CHAT=86400
CACHE_TTL_EMBEDDINGS=604800
